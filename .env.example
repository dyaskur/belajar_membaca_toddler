# Copy to .env and set the path to your Google Cloud service-account JSON key.
# Used by `npm run generate:audio` only (build-time, never shipped to the app).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-key.json

# ElevenLabs API key (for the child voice). Build-time only.
ELEVENLABS_API_KEY=your-elevenlabs-key
